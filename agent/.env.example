# Anthropic API Key (required for Claude models)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OAGI API Key (required for Lux models: lux-actor-1, lux-thinker-1)
# OAGI_API_KEY=...

# Dexbox server URL (default: http://localhost:8600)
# DEXBOX_URL=http://localhost:8600

# Target VM name (default: auto-detect; required when multiple VMs exist)
# DEXBOX_VM=desktop-1

# LLM model to use (default: claude-sonnet-4-20250514)
# DEXBOX_MODEL=claude-sonnet-4-20250514

# Host/guest shared folder (default: ~/.dexbox/shared)
# DEXBOX_SHARED_DIR=~/.dexbox/shared

# Extend AI API Key (for document parsing via parse_document tool)
# EXTEND_API_KEY=sk_...
