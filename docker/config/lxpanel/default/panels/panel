# lxpanel <profile> config file

Global {
    edge=bottom
    allign=left
    margin=0
    widthtype=percent
    width=100
    height=40
    transparent=0
    tintcolor=#1a1a1a
    alpha=255
    autohide=0
    heightwhenhidden=2
    setdocktype=1
    setpartialstrut=1
    usefontcolor=1
    fontsize=10
    fontcolor=#ecf0f1
    usefontsize=0
    background=1
    backgroundfile=
    iconsize=32
}

Plugin {
    type=space
    Config {
        Size=2
    }
}

Plugin {
    type=launchbar
    Config {
        Button {
            id=/home/dexbox/.config/lxpanel/applications/chromium-custom.desktop
        }
        Button {
            id=/home/dexbox/.config/lxpanel/applications/calc-custom.desktop
        }
        Button {
            id=/home/dexbox/.config/lxpanel/applications/xterm-custom.desktop
        }
        Button {
            id=/home/dexbox/.config/lxpanel/applications/gedit-custom.desktop
        }
    }
}

Plugin {
    type=space
    Config {
        Size=4
    }
}

Plugin {
    type=taskbar
    expand=1
    Config {
        tooltips=0
        IconsOnly=0
        ShowAllDesks=0
        UseMouseWheel=1
        UseUrgencyHint=1
        FlatButton=0
        MaxTaskWidth=200
        spacing=1
        GroupedTasks=0
    }
}

