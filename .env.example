# Anthropic API Key (Required)
ANTHROPIC_API_KEY=sk-ant-api03-...

# LLM model to use
# DEXBOX_MODEL=claude-haiku-4-5-20251001

# Logging level (DEBUG, INFO, WARN, ERROR)
# DEXBOX_LOG_LEVEL=INFO

# Desktop backend strategy (rdp or linux-desktop)
# DEXBOX_BACKEND=linux-desktop

# RDP Configuration (Required if DEXBOX_BACKEND=rdp)
# RDP_HOST=
# RDP_USERNAME=
# RDP_PASSWORD=
# RDP_SECURITY=rdp
# RDP_RETRY_DELAY_SECONDS=60
