# Anthropic API Key (Required)
ANTHROPIC_API_KEY=sk-ant-api03-...

# LLM model to use
# DEXBOX_MODEL=claude-haiku-4-5-20251001

# Logging level (DEBUG, INFO, WARN, ERROR)
# DEXBOX_LOG_LEVEL=INFO

# Comma-separated container host paths accessible to workflows
# DRIVE_PATHS=/mnt/tmp,/home/dexbox

# Sandbox container image
# DEXBOX_SANDBOX_IMAGE=dexbox-sandbox-python:latest

# Sandbox image pull policy (never, always)
# DEXBOX_SANDBOX_PULL_POLICY=never

# Max workflow duration in seconds
# DEXBOX_SANDBOX_TIMEOUT=600

# Desktop backend strategy (rdp or linux-desktop)
# DEXBOX_BACKEND=linux-desktop

# RDP Configuration (Required if DEXBOX_BACKEND=rdp)
# RDP_HOST=
# RDP_USERNAME=
# RDP_PASSWORD=
# RDP_SECURITY=rdp
# RDP_RETRY_DELAY_SECONDS=60
