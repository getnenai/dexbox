# Dexbox Server Configuration
# These variables configure the dexbox tool server (Go CLI).
# For agent-specific env vars (API keys, model), see agent/.env.example

# VM Configuration
# DEXBOX_VM_NAME=dexbox-win11
# DEXBOX_VM_USER=dexbox
# DEXBOX_VM_PASS=dexbox123

# VirtualBox SOAP endpoint
# DEXBOX_SOAP_ADDR=http://localhost:18083

# Host-side shared folder path
# DEXBOX_SHARED_DIR=~/.dexbox/shared

# Server listen address
# DEXBOX_LISTEN=:8600

# Screenshot dimensions (resize before returning to agent)
# DEXBOX_SCREENSHOT_WIDTH=1024
# DEXBOX_SCREENSHOT_HEIGHT=768
